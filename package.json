{
    "name": "@cutoff/audio-ui",
    "description": "AudioUI by Cutoff - React component library for audio and MIDI applications",
    "version": "1.0.0-preview.20260410.2025",
    "type": "module",
    "private": true,
    "author": "Renaud Denis <mail@renauddenis.com> (https://renauddenis.com)",
    "license": "GPL-3.0-only",
    "homepage": "https://cutoff.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cutoff/audio-ui.git"
    },
    "bugs": {
        "url": "https://github.com/cutoff/audio-ui/issues"
    },
    "packageManager": "pnpm@10.28.2",
    "scripts": {
        "dev": "turbo dev",
        "typecheck": "turbo typecheck",
        "build": "turbo build",
        "start": "turbo start",
        "test": "turbo test",
        "lint": "turbo lint --continue",
        "lint:fix": "turbo lint:fix --continue",
        "check": "pnpm install && turbo run typecheck build lint test",
        "clean": "(pnpm exec turbo clean || true) && rm -rf node_modules .turbo",
        "clean-build": "pnpm clean && pnpm i && pnpm build",
        "format": "prettier --write .",
        "version": "tsx scripts/version.ts",
        "release:prepare": "tsx scripts/release-prepare.ts",
        "release:dev": "tsx scripts/release-dev.ts"
    },
    "keywords": [
        "react",
        "audio",
        "midi",
        "components"
    ],
    "pnpm": {
        "overrides": {
            "rollup": "^4.59.0",
            "eslint>minimatch": "3.1.4",
            "eslint-plugin-react>minimatch": "3.1.4",
            "@eslint/eslintrc>minimatch": "3.1.4",
            "@typescript-eslint/typescript-estree>minimatch": "9.0.7",
            "@vue/language-core>minimatch": "9.0.7",
            "flat-cache>flatted": "^3.4.2",
            "lodash": "^4.18.0",
            "lodash-es": "^4.18.0",
            "ajv@<7": "^6.14.0",
            "ajv@^8.0.0": "^8.18.0",
            "yaml": "^2.8.3",
            "brace-expansion@^1.0.0": "1.1.13",
            "brace-expansion@^2.0.0": "2.0.3",
            "picomatch@^2.0.0": "2.3.2",
            "picomatch@^4.0.0": "4.0.4",
            "defu": "^6.1.5"
        }
    },
    "dependencies": {
        "turbo": "^2.7.6"
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.1",
        "@eslint/js": "^9.39.2",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "^8.54.0",
        "eslint": "^9.39.2",
        "eslint-plugin-license-header": "^0.8.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "vitest": "^3.2.4"
    }
}
