{
    "name": "@cutoff/audio-ui-core",
    "version": "1.0.0-preview.20260410.2025",
    "description": "Core logic and models for AudioUI by Cutoff",
    "private": false,
    "author": "Renaud Denis <mail@renauddenis.com> (https://renauddenis.com)",
    "license": "GPL-3.0-only",
    "homepage": "https://cutoff.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cutoff/audio-ui.git",
        "directory": "packages/core"
    },
    "bugs": {
        "url": "https://github.com/cutoff/audio-ui/issues"
    },
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "sideEffects": [
        "**/*.css"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./styles.css": "./dist/styles/styles.css",
        "./themes.css": "./dist/styles/themes.css",
        "./fonts.css": "./dist/styles/fonts.css",
        "./styles-with-font.css": "./dist/styles/styles-with-font.css"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "pnpm exec vite build",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix || true",
        "clean": "rm -rf node_modules dist .turbo"
    },
    "dependencies": {
        "fast-deep-equal": "^3.1.3"
    },
    "devDependencies": {
        "jsdom": "^24.1.3",
        "typescript": "^5.9.3",
        "vite": "^6.4.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^3.2.4"
    }
}
